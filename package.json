{
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mdx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx,.mdx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "vitest run && playwright test",
    "check-all": "pnpm run type-check && pnpm run lint",
    "pre-commit": "pnpm run type-check && pnpm run lint:fix && pnpm run test"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@upstash/redis": "^1.38.0",
    "bright": "^1.0.0",
    "clsx": "^2.1.1",
    "eslint-config-next": "16.2.10",
    "geist": "^1.7.2",
    "gray-matter": "^4.0.3",
    "install": "^0.13.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-mdx-remote": "^6.0.0",
    "next-transition-router": "^0.2.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.7.0",
    "reading-time": "^1.5.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "19.2.17",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-mdx": "^3.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "4.3.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.5.0"
}
